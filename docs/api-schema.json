{
  "openapi": "3.0.0",
  "info": { "title": "Demo API", "version": "1.0.0" },
  "paths": {
    "/auth/register": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "name", "turnstileToken"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "name": { "type": "string" },
                  "turnstileToken": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "turnstileToken"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "turnstileToken": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
